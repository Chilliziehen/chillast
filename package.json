{
  "name": "chillast",
  "version": "0.0.2",
  "description": "CHILLAST — a professional desktop astrology studio for natal, transit, synastry and composite charts.",
  "author": "CHILLAST",
  "license": "MIT",
  "main": "src/main/Main.js",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "test": "node tests/RunAll.js",
    "smoke": "node tests/SmokeRenderer.js",
    "rebuild": "electron-rebuild -f --only swisseph-v2",
    "rebuild:node": "npm rebuild swisseph-v2",
    "build:index": "node tools/build-index.mjs",
    "stage:index": "node tools/stage-index.mjs",
    "predist": "electron-rebuild -f --only swisseph-v2",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.chillast.astrology",
    "productName": "CHILLAST",
    "npmRebuild": false,
    "files": [
      "src/**/*",
      "fonts/**/*",
      "locale/**/*",
      "vendor/sxwnl/src/**/*.js",
      "config.json",
      "package.json"
    ],
    "asarUnpack": [
      "src/core/ai/EmbeddingWorker.js",
      "node_modules/onnxruntime-node/**",
      "node_modules/@huggingface/transformers/**",
      "node_modules/hnswlib-node/**",
      "node_modules/swisseph-v2/**"
    ],
    "extraResources": [
      { "from": "assets", "to": "assets" },
      { "from": "resources/models", "to": "models" },
      { "from": "resources/vector-index", "to": "vector-index" }
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "artifactName": "${productName}-${version}-setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    }
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@langchain/anthropic": "^0.3.0",
    "@langchain/community": "^0.3.0",
    "@langchain/core": "^0.3.0",
    "@langchain/langgraph": "^0.2.74",
    "@langchain/mcp-adapters": "^0.6.0",
    "@langchain/openai": "^0.3.0",
    "@modelcontextprotocol/sdk": "^1.12.3",
    "circular-natal-horoscope-js": "^1.1.0",
    "hnswlib-node": "^3.0.0",
    "langchain": "^0.3.0",
    "luxon": "^3.7.2",
    "pdf-parse": "^1.1.1",
    "swisseph-v2": "^1.0.0",
    "tz-lookup": "^6.1.24",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.0",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3"
  }
}
